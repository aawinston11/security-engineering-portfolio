# Copy to .env at the repo root and fill in your keys.
# .env is gitignored — secrets stay local.

# ----- API keys -----
# Required if LLM_BACKEND=anthropic (default).
ANTHROPIC_API_KEY=sk-ant-...

# Required if LLM_BACKEND=openai.
OPENAI_API_KEY=sk-...

# ----- Backend selection -----
# Which LLM provider to use. One of: anthropic | openai | ollama
# Default: anthropic
# LLM_BACKEND=anthropic

# ----- Model overrides -----
# Anthropic — default is claude-sonnet-4-6. Override for max intelligence:
# ANTHROPIC_MODEL=claude-opus-4-7

# OpenAI — default is gpt-5-mini. Override for max intelligence:
# OPENAI_MODEL=gpt-5

# OpenAI reasoning effort — default is medium. Set empty to omit (e.g. for
# non-reasoning models that 400 on the parameter):
# OPENAI_REASONING_EFFORT=medium

# ----- Ollama (when the LLM lab box is online) -----
# OLLAMA_MODEL=qwen2.5:14b-instruct-q4_K_M
# OLLAMA_HOST=http://llm-lab-01:11434
